<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="52dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:letterSpacing="0.2"
                    android:text="AETHER"
                    android:textColor="@color/on_surface"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Settings" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:paddingHorizontal="24dp"
                android:letterSpacing="0.08"
                android:text="CURRENT STATE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="9sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:paddingHorizontal="24dp"
                android:fontFamily="serif"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.15"
                android:text="Quiet your mind\ninto the flow."
                android:textColor="@color/on_surface"
                android:textSize="32sp" />

            <!-- Featured card -->
            <FrameLayout
                android:id="@+id/featured_card"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_featured_card" />

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_play_circle_white">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_white"
                        android:contentDescription="Play" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.08"
                        android:text="DAILY RITUAL"
                        android:textAllCaps="true"
                        android:textColor="#AAFFFFFF"
                        android:textSize="9sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:text="Celestial Echoes"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Deep focus meditation with singing bowls."
                        android:textColor="#BBFFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp">
                <TextView
                    android:id="@+id/section_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.08"
                    android:text="RECOMMENDED FOR YOU"
                    android:textAllCaps="true"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="9sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.05"
                    android:text="VIEW ALL"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sound_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="24dp"
                android:letterSpacing="0.08"
                android:text="MINDFULNESS NOTE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="9sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="24dp"
                android:fontFamily="serif"
                android:lineSpacingMultiplier="1.6"
                android:text="Sound is not just a frequency, it is a vessel for presence. Notice how the space between the notes allows for deeper reflection."
                android:textColor="@color/on_surface"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Floating nav - overlays content -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingHorizontal="32dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_floating_nav"
            android:elevation="12dp"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/tab_home"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_waves"
                android:tint="@color/on_surface"
                android:contentDescription="Home" />

            <ImageView
                android:id="@+id/tab_sounds"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_home"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Sounds" />

            <ImageView
                android:id="@+id/tab_nature"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_sparkle"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Discover" />

            <ImageView
                android:id="@+id/tab_favorites"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_profile"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Profile" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
