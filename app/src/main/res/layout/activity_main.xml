<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="16dp">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:letterSpacing="0.15"
                    android:text="AETHER"
                    android:textColor="@color/on_surface"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Settings" />
            </LinearLayout>

            <!-- Current State label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.05"
                android:text="CURRENT STATE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp" />

            <!-- Hero text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.1"
                android:text="Quiet your mind\ninto the flow."
                android:textColor="@color/on_surface"
                android:textSize="30sp" />

            <!-- Featured card -->
            <LinearLayout
                android:id="@+id/featured_card"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_featured_card"
                android:gravity="bottom"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.05"
                    android:text="DAILY RITUAL"
                    android:textAllCaps="true"
                    android:textColor="@color/on_primary"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Celestial Echoes"
                    android:textColor="@color/surface_container_lowest"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Deep focus meditation with singing bowls."
                    android:textColor="#CCFFFFFF"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Recommended label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.05"
                    android:text="RECOMMENDED FOR YOU"
                    android:textAllCaps="true"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="10sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VIEW ALL"
                    android:textColor="@color/primary"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Sound list -->
            <LinearLayout
                android:id="@+id/sound_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />

            <!-- Mindfulness quote -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.05"
                android:text="MINDFULNESS NOTE"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:lineSpacingMultiplier="1.5"
                android:text="Sound is not just a frequency, it is a vessel for presence. Notice how the space between the notes allows for deeper reflection."
                android:textColor="@color/on_surface"
                android:textSize="14sp" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface_container_lowest"
        android:elevation="4dp"
        android:gravity="center">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:src="@drawable/ic_leaf"
            android:contentDescription="Home" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:src="@drawable/ic_wind"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Sounds" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:src="@drawable/ic_rain"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Nature" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="24dp"
            android:layout_weight="1"
            android:src="@drawable/ic_heart"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Favorites" />
    </LinearLayout>

</LinearLayout>
