<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="48dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="-0.02"
        android:text="Meditation Timer"
        android:textColor="@color/on_surface"
        android:textSize="28sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Set your session duration."
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp" />

    <!-- Timer display -->
    <FrameLayout
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginTop="48dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_timer_circle" />

        <TextView
            android:id="@+id/timer_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="sans-serif-light"
            android:text="10:00"
            android:textColor="@color/on_surface"
            android:textSize="48sp" />
    </FrameLayout>

    <!-- Duration presets -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_5min"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_category_chip"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="5 min"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_10min"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_category_chip"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="10 min"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_20min"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_category_chip"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="20 min"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_30min"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_category_chip"
            android:gravity="center"
            android:paddingHorizontal="20dp"
            android:text="30 min"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Start/Stop button -->
    <TextView
        android:id="@+id/btn_timer_toggle"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_pill_button"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:paddingHorizontal="48dp"
        android:text="Start Timer"
        android:textColor="@color/on_primary"
        android:textSize="15sp" />
</LinearLayout>
