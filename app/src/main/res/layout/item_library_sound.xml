<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_sound_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="12dp">

    <ImageView
        android:id="@+id/lib_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_icon_circle"
        android:padding="10dp"
        android:contentDescription="Sound icon" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/lib_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/on_surface"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/lib_tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.05"
            android:textAllCaps="true"
            android:textColor="@color/on_surface_variant"
            android:textSize="10sp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/lib_bookmark"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Bookmark"
        android:src="@drawable/ic_bookmark"
        android:tint="@color/outline_variant" />
</LinearLayout>
