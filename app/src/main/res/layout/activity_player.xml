<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <!-- Top bar: X / SOUND MIXER / settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp">

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close_x"
            android:contentDescription="Close" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.15"
            android:text="SOUND MIXER"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Sleep timer circle -->
    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp">

        <com.martial.soundplay.ui.TimerRingView
            android:id="@+id/timer_ring"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.1"
                android:text="SLEEP TIMER"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/tv_timer_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:text="--"
                android:textColor="@color/on_surface"
                android:textSize="40sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_timer_small"
                android:contentDescription="Timer" />
        </LinearLayout>
    </FrameLayout>

    <!-- Timer presets -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/btn_timer_15"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_play_small"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="15m"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_timer_30"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_play_small"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="30m"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_timer_45"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_play_small"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="45m"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/btn_timer_60"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:background="@drawable/bg_play_small"
            android:gravity="center"
            android:paddingHorizontal="14dp"
            android:text="60m"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Sound cards with volume sliders -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:id="@+id/mixer_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- Bottom control bar: heart / prev / play / next / share -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/surface"
        android:gravity="center"
        android:paddingHorizontal="24dp">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="22dp"
            android:layout_weight="1"
            android:src="@drawable/ic_heart"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Favorite" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="22dp"
            android:layout_weight="1"
            android:src="@drawable/ic_prev"
            android:contentDescription="Previous" />

        <ImageView
            android:id="@+id/btn_play_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_play_button"
            android:padding="16dp"
            android:src="@drawable/ic_pause"
            android:contentDescription="Play/Pause" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="22dp"
            android:layout_weight="1"
            android:src="@drawable/ic_next"
            android:contentDescription="Next" />

        <ImageView
            android:id="@+id/btn_stop_all"
            android:layout_width="0dp"
            android:layout_height="22dp"
            android:layout_weight="1"
            android:src="@drawable/ic_close_x"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Stop all" />
    </LinearLayout>

</LinearLayout>
