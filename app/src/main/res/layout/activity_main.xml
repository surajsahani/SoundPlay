<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="52dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:letterSpacing="0.05"
                    android:text="SoundPlay"
                    android:textColor="@color/on_surface"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/btn_settings"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Settings" />
            </LinearLayout>

            <!-- Greeting -->
            <TextView
                android:id="@+id/greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:paddingHorizontal="24dp"
                android:fontFamily="sans-serif"
                android:textColor="@color/on_surface"
                android:textSize="26sp" />

            <!-- Mood chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="24dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/mood_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal" />
            </HorizontalScrollView>

            <!-- Featured card -->
            <FrameLayout
                android:id="@+id/featured_card"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="20dp">

                <!-- Background image placeholder (teal gradient) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_featured_card_image" />

                <!-- Dark overlay for text readability -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_featured_overlay" />

                <!-- Content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.1"
                        android:text="FEATURED SESSION"
                        android:textAllCaps="true"
                        android:textColor="#AAFFFFFF"
                        android:textSize="9sp" />

                    <TextView
                        android:id="@+id/featured_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="serif"
                        android:text="Deep Forest"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginTop="4dp"
                        android:text="Immersive 3D audio landscape recorded in the heart of the Pacific Northwest."
                        android:textColor="#BBFFFFFF"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- Play button -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="20dp"
                    android:background="@drawable/bg_play_circle_white">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_white"
                        android:contentDescription="Play" />
                </FrameLayout>
            </FrameLayout>

            <!-- Recommended section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="24dp">

                <TextView
                    android:id="@+id/section_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:letterSpacing="0.08"
                    android:text="RECOMMENDED FOR YOU"
                    android:textAllCaps="true"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="9sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.05"
                    android:text="VIEW ALL"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="9sp" />
            </LinearLayout>

            <!-- Sound list -->
            <LinearLayout
                android:id="@+id/sound_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:paddingHorizontal="24dp" />

            <!-- Quote -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="16dp"
                android:paddingHorizontal="40dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="&quot;Presence is the greatest gift.&quot;"
                android:textColor="@color/on_surface_variant"
                android:textSize="14sp"
                android:textStyle="italic" />

        </LinearLayout>
    </ScrollView>

    <!-- Mixing bar -->
    <LinearLayout
        android:id="@+id/mixing_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="80dp"
        android:background="@drawable/bg_floating_nav"
        android:gravity="center"
        android:paddingHorizontal="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/mixing_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/on_surface"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/btn_open_mixer"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_pill_button"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:text="MIXER"
            android:textColor="@color/on_primary"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Floating nav -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingHorizontal="32dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_floating_nav"
            android:gravity="center"
            android:paddingHorizontal="16dp">

            <ImageView
                android:id="@+id/tab_home"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_waves"
                android:tint="@color/on_surface"
                android:contentDescription="Home" />

            <ImageView
                android:id="@+id/tab_sounds"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_sparkle"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Sounds" />

            <ImageView
                android:id="@+id/tab_nature"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:src="@drawable/ic_timer_small"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Timer" />

            <ImageView
                android:id="@+id/tab_favorites"
                android:layout_width="0dp"
                android:layout_height="22dp"
                android:layout_weight="1"
                android:src="@drawable/ic_nav_profile"
                android:tint="@color/on_surface_variant"
                android:contentDescription="Profile" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
