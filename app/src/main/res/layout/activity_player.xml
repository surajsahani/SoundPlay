<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_hero"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="32dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Close"
                android:src="@drawable/ic_close" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Meditation Session"
                android:textColor="@color/on_surface"
                android:textSize="16sp" />

            <View
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>

        <!-- Large icon circle -->
        <FrameLayout
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="40dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_icon_circle" />

            <ImageView
                android:id="@+id/player_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:contentDescription="Sound icon" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/player_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.02"
            android:textColor="@color/on_surface"
            android:textSize="28sp" />

        <!-- Tags -->
        <TextView
            android:id="@+id/player_tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.05"
            android:textAllCaps="true"
            android:textColor="@color/on_surface_variant"
            android:textSize="11sp" />

        <!-- Glass controls panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:background="@drawable/bg_glass_panel"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="28dp">

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="4dp"
                android:minHeight="4dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/surface_container_lowest"
                android:progressBackgroundTint="@color/surface_container_highest" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_current_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_total_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Playback controls -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btn_prev"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous"
                    android:src="@drawable/ic_skip_back" />

                <ImageButton
                    android:id="@+id/btn_play_pause"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginHorizontal="36dp"
                    android:background="@drawable/bg_play_button"
                    android:contentDescription="Play/Pause"
                    android:padding="18dp"
                    android:src="@drawable/ic_pause" />

                <ImageButton
                    android:id="@+id/btn_next"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next"
                    android:src="@drawable/ic_skip_forward" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom action row (volume, timer, stop, bookmark) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_daily_ritual"
            android:gravity="center"
            android:paddingVertical="16dp">

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Volume"
                android:src="@drawable/ic_whitenoise"
                android:padding="12dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_icon_circle"
                android:contentDescription="Timer"
                android:src="@drawable/ic_timer"
                android:padding="12dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Stop"
                android:src="@drawable/ic_close"
                android:padding="12dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginHorizontal="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Bookmark"
                android:src="@drawable/ic_bookmark"
                android:padding="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
