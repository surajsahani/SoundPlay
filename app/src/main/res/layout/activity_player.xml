<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_hero"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <!-- Top bar: X / AETHER / settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp">

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_close_x"
            android:contentDescription="Close" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:letterSpacing="0.2"
            android:text="AETHER"
            android:textColor="@color/on_surface"
            android:textSize="13sp" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Spacer to push circle to vertical center area -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Icon circle with pulse rings -->
    <FrameLayout
        android:layout_width="260dp"
        android:layout_height="260dp">

        <com.martial.soundplay.ui.PulseView
            android:id="@+id/pulse_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_icon_circle" />

        <ImageView
            android:id="@+id/player_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_leaf"
            android:contentDescription="Sound icon" />
    </FrameLayout>

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Glass control panel at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:background="@drawable/bg_glass_panel"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp">

        <!-- Seekbar -->
        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="3dp"
            android:minHeight="3dp"
            android:progress="42"
            android:max="100"
            android:progressTint="@color/primary"
            android:thumbTint="@color/primary_container"
            android:progressBackgroundTint="@color/surface_container_highest" />

        <!-- Time labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/tv_current"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12:45"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tv_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30:00"
                android:textColor="@color/on_surface_variant"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Prev / Play / Next -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_prev"
                android:contentDescription="Previous" />

            <ImageView
                android:id="@+id/btn_play_pause"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_marginHorizontal="36dp"
                android:background="@drawable/bg_play_button"
                android:padding="20dp"
                android:src="@drawable/ic_pause"
                android:contentDescription="Play/Pause" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_next"
                android:contentDescription="Next" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom info: volume / timer / heart -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_volume"
            android:tint="@color/on_surface"
            android:contentDescription="Volume" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="65%"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="28dp"
            android:src="@drawable/ic_timer_small"
            android:contentDescription="Timer" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:letterSpacing="0.05"
            android:text="15M REMAINING"
            android:textAllCaps="true"
            android:textColor="@color/on_surface"
            android:textSize="11sp" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="28dp"
            android:src="@drawable/ic_heart"
            android:tint="@color/on_surface"
            android:contentDescription="Favorite" />
    </LinearLayout>

</LinearLayout>
